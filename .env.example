# StreetSense environment configuration
# Copy to .env and fill in values before running.

# ---------------------------------------------------------------------------
# LLM Provider (pick one — defaults to Ollama if no key is set)
# ---------------------------------------------------------------------------

# Option 1: Ollama (local, default — no key required)
# Mac dev: qwen2.5:14b | NVIDIA GB10: nemotron-mini | quick test: gemma4:latest
STREETSENSE_MODEL=gemma4:latest
OLLAMA_BASE_URL=http://localhost:11434

# Option 2: Claude (Anthropic) — pip install anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-haiku-4-5-20251001   # default; any Claude model works

# Option 3: OpenAI — pip install openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini                 # default

# Option 4: Google Gemini — pip install google-generativeai
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-2.0-flash            # default

# Explicit override (overrides auto-detection from API keys above)
# LLM_PROVIDER=ollama   # ollama | claude | openai | google

# ---------------------------------------------------------------------------
# Geocoder
# ---------------------------------------------------------------------------

# "nominatim" (real, Nominatim rate-limited) or "demo" (offline street-centroid fallback)
STREETSENSE_GEOCODER=nominatim

# Geocode rate limit in seconds (Nominatim policy: 1 req/sec)
GEOCODE_DELAY=1.0

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------

# Slack webhook for operational brief notifications
# Get from: Slack App → Incoming Webhooks → Copy URL
SLACK_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Map tiles
# ---------------------------------------------------------------------------

# Mapbox public token for map tiles (free tier at mapbox.com)
MAPBOX_TOKEN=
